FROM ubuntu:24.04 AS builder
RUN apt-get update && apt-get install -y build-essential cmake git curl zip
RUN git clone https://github.com/microsoft/vcpkg.git && ./vcpkg/bootstrap-vcpkg.sh
WORKDIR /app
COPY . .
RUN cmake -B build -S . -DCMAKE_TOOLCHAIN_FILE=/vcpkg/scripts/buildsystems/vcpkg.cmake -DCMAKE_BUILD_TYPE=Release
RUN cmake --build build --config Release -j$(nproc)

FROM ubuntu:24.04
RUN apt-get update && apt-get install -y ca-certificates openssl && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/build/reverse_proxy /usr/local/bin/
COPY configs /configs
EXPOSE 8443
CMD ["reverse_proxy"]
